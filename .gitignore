# Keep workflow subdirectory structure,
# but ignore generated documents inside them.
workflow/requirements/*
!workflow/requirements/.gitkeep

workflow/plans/*
!workflow/plans/.gitkeep

workflow/summaries/*
!workflow/summaries/.gitkeep

# workflow/ inside .docs/ or docs/
.docs/workflow/requirements/*
!.docs/workflow/requirements/.gitkeep
.docs/workflow/plans/*
!.docs/workflow/plans/.gitkeep
.docs/workflow/summaries/*
!.docs/workflow/summaries/.gitkeep

docs/workflow/requirements/*
!docs/workflow/requirements/.gitkeep
docs/workflow/plans/*
!docs/workflow/plans/.gitkeep
docs/workflow/summaries/*
!docs/workflow/summaries/.gitkeep

# .workflow/ (hidden variant)
.workflow/requirements/*
!.workflow/requirements/.gitkeep
.workflow/plans/*
!.workflow/plans/.gitkeep
.workflow/summaries/*
!.workflow/summaries/.gitkeep

# .workflow/ inside .docs/ or docs/
.docs/.workflow/requirements/*
!.docs/.workflow/requirements/.gitkeep
.docs/.workflow/plans/*
!.docs/.workflow/plans/.gitkeep
.docs/.workflow/summaries/*
!.docs/.workflow/summaries/.gitkeep

docs/.workflow/requirements/*
!docs/.workflow/requirements/.gitkeep
docs/.workflow/plans/*
!docs/.workflow/plans/.gitkeep
docs/.workflow/summaries/*
!docs/.workflow/summaries/.gitkeep
